<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart_Store_For_Clothes</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Smart_Store_For_Clothes.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="custom-navbar">
            <div class="custom-navbar-container">
                <div class="custom-navbar-left">
                    <a class="custom-brand" asp-area="Customer" asp-controller="Home" asp-action="Index">
                        Smart Store
                    </a>

                    <div class="custom-nav-links">
                        <a asp-area="Customer" asp-controller="Home" asp-action="Index">Home</a>
                    </div>
                </div>

                <div class="custom-auth">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <a class="cart-btn" asp-area="Customer" asp-controller="Cart" asp-action="Index">
                            <span class="cart-icon">🛒</span>
                            <span>Cart</span>
                        </a>

                        <span class="user-greeting">Hello, @User.Identity.Name</span>

                        <form asp-area="Identity" asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="logout-btn">Logout</button>
                        </form>
                    }
                    else
                    {
                        <a class="login-btn" asp-area="Identity" asp-controller="Account" asp-action="Login">Login</a>
                        <a class="register-btn" asp-area="Identity" asp-controller="Account" asp-action="Register">Register</a>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Smart_Store_For_Clothes - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
