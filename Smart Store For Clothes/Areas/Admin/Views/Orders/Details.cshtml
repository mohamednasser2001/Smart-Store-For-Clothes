@model Models.VM.OrderDetailsVM

@{
    ViewData["Title"] = "Order Details";
}

<link rel="stylesheet" href="~/css/Admin/order-details.css" />

<div class="container admin-order-details-page">
    <div class="admin-order-header">
        <div>
            <h1>Order Details</h1>
            <p>Review customer information and manage the order status.</p>
        </div>

        <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="back-btn">
            Back to Orders
        </a>
    </div>

    <div class="order-details-grid">
        <div class="details-card">
            <h3>Customer Information</h3>

            <div class="info-list">
                <div class="info-item">
                    <span class="info-label">Order Id</span>
                    <span class="info-value">#@Model.Order.Id</span>
                </div>

                <div class="info-item">
                    <span class="info-label">Order Date</span>
                    <span class="info-value">@Model.Order.OrderDate.ToString("yyyy-MM-dd hh:mm tt")</span>
                </div>

                <div class="info-item">
                    <span class="info-label">Customer Name</span>
                    <span class="info-value">@Model.Order.FullName</span>
                </div>

                <div class="info-item">
                    <span class="info-label">Email</span>
                    <span class="info-value">@Model.Order.Email</span>
                </div>

                <div class="info-item">
                    <span class="info-label">Phone Number</span>
                    <span class="info-value">@Model.Order.PhoneNumber</span>
                </div>

                <div class="info-item">
                    <span class="info-label">City</span>
                    <span class="info-value">@Model.Order.City</span>
                </div>

                <div class="info-item" style="grid-column: 1 / -1;">
                    <span class="info-label">Address</span>
                    <span class="info-value">@Model.Order.Address</span>
                </div>
            </div>
        </div>

        <div class="details-card">
            <h3>Order Summary</h3>

            <div class="summary-box">
                <div class="summary-row">
                    <span>Status</span>
                    <span>
                        @if (Model.Order.Status == "Pending")
                        {
                            <span class="order-status-badge pending-status">Pending</span>
                        }
                        else if (Model.Order.Status == "Accepted")
                        {
                            <span class="order-status-badge accepted-status">Accepted</span>
                        }
                        else
                        {
                            <span class="order-status-badge default-status">@Model.Order.Status</span>
                        }
                    </span>
                </div>

                <div class="summary-row">
                    <span>Subtotal</span>
                    <span>$@Model.Order.SubTotal.ToString("0.00")</span>
                </div>

                <div class="summary-row">
                    <span>Shipping</span>
                    <span>$@Model.Order.ShippingCost.ToString("0.00")</span>
                </div>

                <div class="summary-divider"></div>

                <div class="summary-row total">
                    <span>Total</span>
                    <span>$@Model.Order.Total.ToString("0.00")</span>
                </div>
            </div>

            @if (Model.Order.Status == "Pending")
            {
                <form asp-area="Admin" asp-controller="Orders" asp-action="Accept" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Order.Id" />
                    <button type="submit" class="accept-btn">
                        Accept Order
                    </button>
                </form>
            }
            else
            {
                <div class="accepted-note">
                    <span class="order-status-badge accepted-status">Order Accepted</span>
                </div>
            }
        </div>
    </div>

    <div class="order-items-card">
        <div class="card-header">
            <h3>Order Items</h3>
        </div>

        @if (Model.OrderItems != null && Model.OrderItems.Any())
        {
            <table class="table order-items-table align-middle">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Size</th>
                        <th>Quantity</th>
                        <th>Unit Price</th>
                        <th>Total Price</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderItems)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td>@item.SizeName</td>
                            <td>@item.Quantity</td>
                            <td class="money-value">$@item.UnitPrice.ToString("0.00")</td>
                            <td class="money-value">$@item.TotalPrice.ToString("0.00")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-items">
                No items found for this order.
            </div>
        }
    </div>
</div>