
@model Models.VM.CategoriesIndexVM
@{
    ViewData["Title"] = "Categories";
    ViewData["PageTitle"] = "Categories";
    ViewData["PageDescription"] = "Manage all categories from here";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<link rel="stylesheet" href="/css/Admin/categories.css" />

<section class="categories-page">
    <div class="categories-top">
        <a asp-area="Admin" asp-controller="Categories" asp-action="Create" class="add-category-btn">
            <span class="plus-icon">+</span>
            Add Category
        </a>
    </div>

    <div class="categories-list">
        @if (Model.Categories != null && Model.Categories.Any())
        {
            @foreach (var category in Model.Categories)
            {
                <div class="category-card">
                    <div class="category-left">
                        <div class="category-image-box">
                            <img src="@(string.IsNullOrEmpty(category.ImageUrl) ? "/images/category-placeholder.png" : category.ImageUrl)" alt="Category Image" />
                        </div>

                        <div class="category-info">
                            <h3>@category.Name</h3>
                            <p>Products: @category.ProductsCount</p>
                        </div>
                    </div>

                    <div class="category-actions">
                        <a asp-action="Edit" asp-route-id="@category.Id" class="edit-btn">Edit</a>
                        <form asp-action="DeleteConfirmed" asp-route-id="@category.Id" method="post" class="delete-form">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="delete-btn">Delete</button>
                        </form>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="content-box">
                <h3>No Categories Yet</h3>
                <p>Start by adding your first category.</p>
            </div>
        }
    </div>
    @if (Model.TotalPages > 1)
    {
        <div class="pagination-container">
            @if (Model.CurrentPage > 1)
            {
                <a asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" class="pagination-btn">Previous</a>
            }

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <a asp-action="Index"
                       asp-route-page="@i"
                       class="pagination-btn @(i == Model.CurrentPage ? "active-page" : "")">
                    @i
                </a>
            }

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <a asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" class="pagination-btn">Next</a>
            }
        </div>
    }
</section>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.querySelectorAll('.delete-form').forEach(form => {
        form.addEventListener('submit', function (e) {
        e.preventDefault();

        Swal.fire({
        title: 'Are you sure?',
        text: "This category will be deleted permanently!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#5b4df3',
        cancelButtonColor: '#d33',
        confirmButtonText: 'Yes, delete it',
        cancelButtonText: 'Cancel'
        }).then((result) => {
        if (result.isConfirmed) {
        form.submit();
        }
        });
        });
        });
    </script>
}